# ---------------------------------------------------------------------------
# City Simulation Engine — environment variable template
# Copy this file to .env and fill in real values. Never commit .env.
# ---------------------------------------------------------------------------

# MongoDB connection string (Atlas or local)
MONGO_URI=mongodb://localhost:27017/city_sim

# Anthropic API key — used only for narrative text generation
ANTHROPIC_API_KEY=sk-ant-...

# Mapbox public token — used by the frontend map visualisation
MAPBOX_TOKEN=pk.eyJ1...
