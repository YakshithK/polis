# ---------------------------------------------------------------------------
# Polis — environment variable template
# Copy this file to .env and fill in real values. Never commit .env.
# ---------------------------------------------------------------------------

# MongoDB connection string (Atlas or local)
MONGO_URI=mongodb://localhost:27017/polis

# Hack Club AI key — used only for narrative text generation
# Get yours at: https://ai.hackclub.com/dashboard
HACKCLUB_AI_KEY=hc-...

# Mapbox public token — used by the frontend map visualisation
MAPBOX_TOKEN=pk.eyJ1...
